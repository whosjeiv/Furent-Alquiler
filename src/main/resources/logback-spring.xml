<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- FURENT - Logging Profesional con Logback               -->
    <!-- Dev: Console legible | Prod: JSON estructurado         -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <property name="LOG_PATH" value="${LOG_PATH:-logs}" />
    <property name="APP_NAME" value="furent" />

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PROFILE: DEVELOPMENT - Console legible y colorida      -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n</pattern>
            </encoder>
        </appender>

        <appender name="FILE_DEV" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/furent-dev.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/furent-dev.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>7</maxHistory>
                <totalSizeCap>100MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE_DEV" />
        </root>
    </springProfile>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PROFILE: PRODUCTION - JSON estructurado para ELK/Loki  -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <springProfile name="prod">
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/furent.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/furent.%d{yyyy-MM-dd}.%i.json.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"application":"${APP_NAME}","environment":"production"}</customFields>
                <includeCallerData>false</includeCallerData>
            </encoder>
        </appender>

        <appender name="CONSOLE_PROD" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"application":"${APP_NAME}"}</customFields>
            </encoder>
        </appender>

        <!-- Archivo de seguridad separado -->
        <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/furent-security.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/furent-security.%d{yyyy-MM-dd}.%i.json.gz</fileNamePattern>
                <maxFileSize>25MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"application":"${APP_NAME}","log_type":"security"}</customFields>
            </encoder>
        </appender>

        <!-- Archivo de auditoría separado -->
        <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/furent-audit.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/furent-audit.%d{yyyy-MM-dd}.%i.json.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>365</maxHistory>
                <totalSizeCap>10GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"application":"${APP_NAME}","log_type":"audit"}</customFields>
            </encoder>
        </appender>

        <!-- Logger de seguridad -->
        <logger name="com.alquiler.furent.config.AuthenticationAuditListener" level="INFO" additivity="false">
            <appender-ref ref="SECURITY_FILE" />
            <appender-ref ref="CONSOLE_PROD" />
        </logger>

        <!-- Logger de auditoría -->
        <logger name="com.alquiler.furent.service.AuditLogService" level="INFO" additivity="false">
            <appender-ref ref="AUDIT_FILE" />
            <appender-ref ref="CONSOLE_PROD" />
        </logger>

        <!-- Logger de eventos -->
        <logger name="com.alquiler.furent.event" level="INFO" additivity="false">
            <appender-ref ref="AUDIT_FILE" />
            <appender-ref ref="CONSOLE_PROD" />
        </logger>

        <root level="INFO">
            <appender-ref ref="CONSOLE_PROD" />
            <appender-ref ref="JSON_FILE" />
        </root>
    </springProfile>

</configuration>
