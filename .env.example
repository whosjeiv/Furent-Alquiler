# Furent - Variables de Entorno de Ejemplo
# Copia este archivo a .env y completa los valores

# ═══════════════════════════════════════════════════════
# BASE DE DATOS
# ═══════════════════════════════════════════════════════
MONGODB_URI=mongodb://localhost:27017/FurentDataBase

# ═══════════════════════════════════════════════════════
# REDIS CACHE
# ═══════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379

# ═══════════════════════════════════════════════════════
# PERFIL DE SPRING
# ═══════════════════════════════════════════════════════
SPRING_PROFILES_ACTIVE=dev

# ═══════════════════════════════════════════════════════
# ADMINISTRADOR
# ═══════════════════════════════════════════════════════
ADMIN_PASSWORD=admin123

# ═══════════════════════════════════════════════════════
# JWT
# ═══════════════════════════════════════════════════════
JWT_SECRET=dGhpcyBpcyBhIHNlY3VyZSBrZXkgZm9yIGZ1cmVudCBzYWFzIHBsYXRmb3JtIDIwMjY=

# ═══════════════════════════════════════════════════════
# GOOGLE OAUTH2
# Obtén estas credenciales en: https://console.cloud.google.com/
# Guía completa: GOOGLE_OAUTH_QUICKSTART.md
# ═══════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# ═══════════════════════════════════════════════════════
# PAYU (Pasarela de Pagos)
# ═══════════════════════════════════════════════════════
PAYU_API_KEY=
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=
PAYU_URL=https://sandbox.checkout.payulatam.com/checkout-web-gateway-payu/
